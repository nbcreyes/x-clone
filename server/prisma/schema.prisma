// Prisma schema for x-clone
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// USER
// Core account model. Handles both credentials and OAuth.
// ------------------------------------------------------------
model User {
  id             String   @id @default(cuid())
  name           String?
  username       String   @unique
  email          String   @unique
  emailVerified  DateTime?
  hashedPassword String?  // null for OAuth users
  bio            String?
  location       String?
  website        String?
  avatarUrl      String?
  coverUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Auth.js relations
  accounts       Account[]
  sessions       Session[]

  // App relations
  posts          Post[]
  likes          Like[]
  retweets       Retweet[]
  replies        Reply[]
  notifications  Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationSender")

  // Follow system - who this user follows
  following      Follow[] @relation("Follower")
  // Follow system - who follows this user
  followers      Follow[] @relation("Following")

  @@map("users")
}

// ------------------------------------------------------------
// AUTH.JS - ACCOUNT
// Stores OAuth provider data (Google, GitHub, etc.)
// One user can have multiple OAuth accounts linked.
// ------------------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ------------------------------------------------------------
// AUTH.JS - SESSION
// Database session strategy.
// Each login creates a session row. Logout deletes it.
// ------------------------------------------------------------
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ------------------------------------------------------------
// AUTH.JS - VERIFICATION TOKEN
// Used for email verification and magic link flows.
// ------------------------------------------------------------
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ------------------------------------------------------------
// POST
// A top-level post (not a reply). Can have an image.
// Replies are a separate model to keep queries clean.
// ------------------------------------------------------------
model Post {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(280) // Twitter's character limit
  imageUrl  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  retweets  Retweet[]
  replies   Reply[]

  // Notifications triggered by this post
  notifications Notification[]

  @@map("posts")
}

// ------------------------------------------------------------
// LIKE
// A user can like a post once. Composite unique prevents duplicates.
// ------------------------------------------------------------
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // one like per user per post
  @@map("likes")
}

// ------------------------------------------------------------
// RETWEET
// A user can retweet a post once.
// ------------------------------------------------------------
model Retweet {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // one retweet per user per post
  @@map("retweets")
}

// ------------------------------------------------------------
// REPLY
// Replies belong to a Post. Replies can also have replies
// (nested threading) via the parent/children self-relation.
// ------------------------------------------------------------
model Reply {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(280)
  imageUrl  String?
  authorId  String
  postId    String   // the top-level post this reply belongs to
  parentId  String?  // null = direct reply to post, set = nested reply

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Self-relation for nested replies (threads)
  parent   Reply?  @relation("ReplyThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Reply[] @relation("ReplyThread")

  notifications Notification[]

  @@map("replies")
}

// ------------------------------------------------------------
// FOLLOW
// Directional follow relationship.
// followerId follows followingId.
// Example: Alice (follower) follows Bob (following).
// ------------------------------------------------------------
model Follow {
  id          String   @id @default(cuid())
  followerId  String   // the user who clicked follow
  followingId String   // the user being followed
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId]) // can only follow someone once
  @@map("follows")
}

// ------------------------------------------------------------
// NOTIFICATION
// Unified notification model for all event types.
// type field determines which optional fields are relevant.
// ------------------------------------------------------------
model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  read       Boolean          @default(false)
  recipientId String          // user receiving the notification
  senderId   String           // user who triggered the notification
  postId     String?          // relevant if type is LIKE, RETWEET, REPLY
  replyId    String?          // relevant if type is REPLY
  createdAt  DateTime         @default(now())

  recipient User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sender    User   @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  post      Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reply     Reply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Notification types - covers all user interactions
enum NotificationType {
  LIKE      // someone liked your post
  RETWEET   // someone retweeted your post
  REPLY     // someone replied to your post
  FOLLOW    // someone followed you
  MENTION   // someone mentioned you in a post
}